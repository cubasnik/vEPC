# vEPC Main Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}

# Mobile Network Operator settings
MCC = {{ plmn_mcc | default('250') }}
MNC = {{ plmn_mnc | default('20') }}

# Network Interface Settings
GTP-C-Port = {{ gtp_c_port | default('2123') }}
GTP-U-Port = {{ gtp_u_port | default('2152') }}
S1AP-Port = {{ s1ap_port | default('36412') }}
Diameter-Port = {{ diameter_port | default('3868') }}

# IP Addresses (if running on host with specific IPs)
{% if vepc_gtp_c_ip is defined %}
GTP-C-IP = {{ vepc_gtp_c_ip }}
{% else %}
GTP-C-IP = 0.0.0.0
{% endif %}

{% if vepc_s1ap_ip is defined %}
S1AP-IP = {{ vepc_s1ap_ip }}
{% else %}
S1AP-IP = 0.0.0.0
{% endif %}

{% if vepc_diameter_ip is defined %}
Diameter-IP = {{ vepc_diameter_ip }}
{% else %}
Diameter-IP = 0.0.0.0
{% endif %}

# MME Settings
MME-Code = 1
MME-Group-ID = 1
MME-Realm = vepc.epc.mnc{{ plmn_mnc3 | default('020') }}.mcc{{ plmn_mcc | default('250') }}.3gppnetwork.org

# SGSN Settings
SGSN-Code = 1
SGSN-Realm = vepc.epc.mnc{{ plmn_mnc3 | default('020') }}.mcc{{ plmn_mcc | default('250') }}.3gppnetwork.org

# HSS Settings
HSS-Realm = hss.epc.mnc{{ plmn_mnc3 | default('020') }}.mcc{{ plmn_mcc | default('250') }}.3gppnetwork.org
HSS-IP = {{ hss_ip | default('127.0.0.1') }}
HSS-Port = {{ hss_port | default('3868') }}

# Logging
Log-Level = {{ log_level | default('info') }}
Log-File = {{ log_path | default('/var/log/vepc') }}/vepc.log
Log-Console = true
Log-Max-Size = 50M
Log-Max-Files = 10

# Runtime Settings
State-File = /var/lib/vepc/runtime.state
Config-Reload-On-Change = true
Auto-Restart-On-Failure = true

# Performance
Max-Connections = 10000
Max-Sessions = 5000
Thread-Pool-Size = {{ ansible_processor_vcpus | default(4) }}
