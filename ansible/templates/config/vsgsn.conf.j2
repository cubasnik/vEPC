# vEPC SGSN Configuration  
# Generated by Ansible on {{ ansible_date_time.iso8601 }}

[SGSN]
# SGSN Identity
Code = 1
Realm = vepc.epc.mnc{{ mnc | default('020') }}.mcc{{ mcc | default('250') }}.3gppnetwork.org

# Gb Interface Configuration (to BSS via BSSGP)
Gb-IP = 0.0.0.0
Gb-Port = 8888
Gb-Protocol = BSSGP
Max-BSC = 50

# Gn Interface Configuration (to GGSN)
Gn-IP = 0.0.0.0
Gn-Port = {{ gtp_c_port | default('2123') }}
GGSN-IP = {{ ggsn_ip | default('127.0.0.1') }}
GGSN-Port = {{ gtp_c_port | default('2123') }}

# Gr Interface Configuration (to HLR)
Gr-IP = 0.0.0.0
Gr-Port = 7777
Gr-Protocol = MAP
HLR-IP = {{ hlr_ip | default('127.0.0.1') }}
HLR-Port = 7777

# Gp Interface Configuration (to GGSN)
Gp-IP = 0.0.0.0
Gp-Port = 2126
GGSNp-IP = {{ ggsnp_ip | default('127.0.0.1') }}
GGSNp-Port = 2126

# Gf Interface Configuration (to EIR)
Gf-IP = 0.0.0.0
Gf-Port = 7779
Gf-Protocol = CAP
EIR-IP = {{ eir_ip | default('127.0.0.1') }}
EIR-Port = 7779

# S3 Interface Configuration (to MME)
S3-IP = 0.0.0.0
S3-Port = 2125
Peer-MME-IP = {{ peer_mme_ip | default('127.0.0.1') }}
Peer-MME-Port = 2125

# Network Configuration
MCC = {{ mcc | default('250') }}
MNC = {{ mnc | default('20') }}
LAC = 1
RAC = 1

# Authentication
Authentication-Method = GSM-MILENAGE
Encryption-Algorithm = GEA-2
Integrity-Check-Type = GPRS

# Timers (in seconds)
T3312 = 3600
T3314 = 300
T3330 = 300

# Subscriber Settings
IMSI-Prefix = 250{{ mnc | default('20') }}
Max-UE = 10000
Default-APN = internet

# PDP Context Configuration
Max-PDP-Contexts = 5000
Default-PDP-Type = IPv4
IP-Pool = {{ ip_pool | default('192.168.0.0/16') }}

# Logging
Log-Level = {{ log_level | default('info') }}
Log-GTP = false
Log-MAP = false
Log-BSSGP = false

# State Persistence
Enable-State-Persistence = true
State-File = /var/lib/vepc/sgsn-state.json
