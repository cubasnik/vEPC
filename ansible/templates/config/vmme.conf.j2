# vEPC MME Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}

[MME]
# MME Identity
Code = 1
GroupID = 1
Realm = vepc.epc.mnc{{ plmn_mnc3 | default('020') }}.mcc{{ plmn_mcc | default('250') }}.3gppnetwork.org

# S1AP Configuration
S1AP-IP = 0.0.0.0
S1AP-Port = {{ s1ap_port | default('36412') }}
S1AP-SCTP-Streams = 10
Max-eNodeB = 100

# S6a Configuration (Diameter)
S6a-IP = 0.0.0.0
S6a-Port = {{ diameter_port | default('3868') }}
HSS-IP = {{ hss_ip | default('127.0.0.1') }}
HSS-Port = {{ hss_port | default('3868') }}
HSS-Realm = hss.epc.mnc{{ plmn_mnc3 | default('020') }}.mcc{{ plmn_mcc | default('250') }}.3gppnetwork.org

# S11 Configuration (GTP-C to S-GW)
S11-IP = 0.0.0.0
S11-Port = {{ gtp_c_port | default('2123') }}
SGW-IP = {{ sgw_ip | default('127.0.0.1') }}
SGW-Port = {{ sgw_port | default('2123') }}

# S10 Configuration (MME to MME)
S10-IP = 0.0.0.0
S10-Port = 2124
Peer-MME-IP = {{ peer_mme_ip | default('127.0.0.1') }}
Peer-MME-Port = 2124

# S3 Configuration (MME to SGSN)
S3-IP = 0.0.0.0
S3-Port = 2125
Peer-SGSN-IP = {{ peer_sgsn_ip | default('127.0.0.1') }}
Peer-SGSN-Port = 2125

# S13 Configuration (EPS authentication)
S13-IP = 0.0.0.0
S13-Port = 3869
EAA-Realm = eaa.epc.mnc{{ plmn_mnc3 | default('020') }}.mcc{{ plmn_mcc | default('250') }}.3gppnetwork.org

# Network Configuration
MCC = {{ plmn_mcc | default('250') }}
MNC = {{ plmn_mnc | default('20') }}
LAC = 1
TAI-List = {{ tai_list | default('1,2,3') }}

# Authentication
Authentication-Method = EPS-AKA
Encryption-Algorithm = 128-EEA2
Integrity-Algorithm = 128-EIA2

# Timers (in seconds)
T3412 = 3600
T3423 = 3600
Timer-Security = 300

# Subscriber Settings
IMSI-Prefix = {{ plmn_mcc | default('250') }}{{ plmn_mnc | default('20') }}
Max-UE = 10000
Default-APN = internet

# Logging
Log-Level = {{ log_level | default('info') }}
Log-S1AP = false
Log-Diameter = false
Log-GTP = false

# State Persistence
Enable-State-Persistence = true
State-File = /var/lib/vepc/mme-state.json
