services:
  vepc:
    build:
      context: .
      dockerfile: Dockerfile
    
    container_name: {{ vepc_container_name }}
    hostname: vepc
    
    cap_add:
      - SYS_ADMIN
      - NET_ADMIN
      - SYS_PTRACE

    # Run as root so CAP_NET_ADMIN is effective for iproute2 VLAN operations.
    user: "0:0"

    # Required for Linux interface operations (create-vlan/bind) on host NICs.
    network_mode: host
    
    volumes:
      - {{ config_path }}:/etc/vepc
      - vepc-logs:{{ log_path }}
      - /var/lib/vepc:/var/lib/vepc
    environment:
      LOG_LEVEL: {{ log_level | default('info') }}
      CONFIG_PATH: /etc/vepc
      LOG_PATH: {{ log_path }}
      VEPC_TRAFFIC_PORTS: '{{ traffic_linux_ports | join(",") }}'
    
    stdin_open: true
    tty: true
    
    restart: unless-stopped
    
    healthcheck:
      test: ["CMD", "/app/vepc-cli", "status"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
        labels: "vepc=core"

volumes:
  vepc-logs:
    driver: local
