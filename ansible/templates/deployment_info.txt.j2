================================================================================
                        QUICK COMMANDS
================================================================================

View container status:
  sudo docker ps -a | grep {{ vepc_container_name }}

View container logs (follow):
  docker logs -f {{ vepc_container_name }}

Access CLI:
  docker exec -it {{ vepc_container_name }} /app/vepc-cli

Show system status:
  docker exec {{ vepc_container_name }} /app/vepc-cli status

Show interface status:
  docker exec {{ vepc_container_name }} /app/vepc-cli show interface

Show configuration:
  docker exec {{ vepc_container_name }} /app/vepc-cli show config

View system logs:
  docker exec {{ vepc_container_name }} /app/vepc-cli log

Restart service:
  sudo systemctl restart vepc

Stop service:
  sudo systemctl stop vepc

Start service:
  sudo systemctl start vepc

View systemd logs:
  journalctl -u vepc -f

