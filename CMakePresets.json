{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026-x64",
      "displayName": "Visual Studio 18 2026 x64",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build-win",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2026-debug",
      "configurePreset": "vs2026-x64",
      "configuration": "Debug"
    },
    {
      "name": "vs2026-release",
      "configurePreset": "vs2026-x64",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "vs2026-release",
      "configurePreset": "vs2026-x64",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}